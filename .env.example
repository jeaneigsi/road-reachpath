REACHPATH_ENVIRONMENT=local
REACHPATH_DRY_RUN=true
REACHPATH_AUTO_EXECUTE=true
REACHPATH_REQUIRE_AUTH=false
# Format production : token-1=workspace-a,token-2=workspace-b
REACHPATH_API_KEYS=
REACHPATH_ADMIN_API_KEYS=
REACHPATH_DATABASE_URL=sqlite:///./reachpath.db
REACHPATH_ARGUS_URL=http://127.0.0.1:8000
REACHPATH_SEARCHSWARM_URL=http://127.0.0.1:8012
REACHPATH_REPORTFORGE_URL=http://127.0.0.1:8011
REACHPATH_ARGUS_API_KEY=
REACHPATH_SEARCHSWARM_API_KEY=
REACHPATH_REPORTFORGE_API_KEY=
REACHPATH_MONTHLY_BUDGET_USD=100
REACHPATH_SERVICE_MAX_RETRIES=2
REACHPATH_SERVICE_RETRY_BACKOFF_SECONDS=0.25
REACHPATH_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
REACHPATH_POSTGRES_DB=reachpath
REACHPATH_POSTGRES_USER=reachpath
REACHPATH_POSTGRES_PASSWORD=CHANGE_ME
REACHPATH_FRONTEND_API_URL=http://api:8020
REACHPATH_FRONTEND_BUILD_API_URL=http://api:8020
REACHPATH_FRONTEND_API_KEY=
REACHPATH_FRONTEND_WORKSPACE_ID=default
REACHPATH_DOMAIN=localhost
REACHPATH_BACKUP_DIR=./backups
